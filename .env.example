# .env.example
# 본 파일을 복사하여 .env 파일을 생성하고 필요한 값을 설정하세요.
# .env 파일은 중요 정보가 포함될 수 있으므로 절대 Git에 업로드하지 마세요. (이미 .gitignore에 포함되어 있어야 합니다)

# ─── Notion API & CLI 연동 설정 ───
# Notion CLI (ntn) 명령이나 API 호출 시 자격 증명 키체인을 오버라이드할 토큰 정보입니다.
NOTION_API_TOKEN=your_notion_integration_token_here
NOTION_WORKSPACE_ID=your_notion_workspace_uuid_here

# ─── 개발 서버 설정 ───
PORT=5173
VITE_APP_TITLE="SUSHI CHOICE Premium Brand Platform"
